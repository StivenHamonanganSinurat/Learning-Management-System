#--------------------------------------------------------------------
# LMS Stikes Nauli Husada - Production Environment Configuration
#--------------------------------------------------------------------
# Copy this file to .env and fill in your production values
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://your-project.vercel.app/'

#--------------------------------------------------------------------
# DATABASE (Supabase PostgreSQL)
#--------------------------------------------------------------------

database.default.hostname = db.xxxxx.supabase.co
database.default.database = postgres
database.default.username = postgres
database.default.password = YOUR_SUPABASE_PASSWORD
database.default.DBDriver = Postgre
database.default.port = 6543

#--------------------------------------------------------------------
# SESSION (Database handler for serverless)
#--------------------------------------------------------------------

session.driver = 'CodeIgniter\Session\Handlers\DatabaseHandler'
session.savePath = 'ci_sessions'
